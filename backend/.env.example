# Server
PORT=3000
NODE_ENV=development

# MySQL Database — use limited user in production (see database/secure-user.sql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=number_display

# Admin login (username + password — password stored as bcrypt hash in MySQL)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT secret — MUST be at least 32 random characters in production
JWT_SECRET=change_this_to_a_long_random_secret_key_at_least_32_chars

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Optional: pre-generated bcrypt hash (run: npm run hash-password -- yourpassword)
# ADMIN_PASSWORD_HASH=$2a$12$...
